;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;                                                                                                             ;;
;; WHIRLPOOL FUNCTIONS                                                                                         ;;
;;                                                                                                             ;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;


;;;
; Compute a WHIRLPOOL hash in native mode
; - param_1: Pointer to the 64-byte value to hash
;;;
<FUN_WhirlPool_Hash>
    ; Get the buffer pointer (should be WHIRLPOOL_BUFFER)
    GET P0, 1

    ; Map the buffer to a block
    MOV C0, 0   ; i
    MOV C1, P0  ; buffer[j] as a ptr
    <LAB_WhirlPool_Hash_MapBufferToBlock>
        ; Compute i for block[i]
        MOV R0, C0
        MUL R0, 8
        MOV [R0 + WHIRLPOOL_BLOCK], 0

        ; Initialize the mask
        MOV R1, 0xFF00000000000000

        ; Build out the block, using a carry-over j
        MOV C2, 0
        <LAB_WhirlPool_Hash_MapBufferToBlockInner>
            ; Get the byte, not in the right place
            MOV R2, [C1]
            AND R2, R1

            ; Shift it to the right place (different than the source way)
            MOV R3, 8
            MUL R3, C2
            SHR R2, R3

            ; Do the XOR
            XOR [R0 + WHIRLPOOL_BLOCK], R2
            SUB C1, 1
            ADD C2, 1
            CMP C2, 8
            JMPC <LAB_WhirlPool_Hash_MapBufferToBlockInner>, LT
        ADD C1, 16

        ; Increment i for next iteration
        ADD C0, 1
        CMP C0, 8
        JMPC <LAB_WhirlPool_Hash_MapBufferToBlock>, LT

    ; Compute and apply K^0 to the cipher state
    MOV C0, 0
    <LAB_WhirlPool_Hash_ApplyK0>
        ; K[i] = hash[i]
        MOV R0, C0
        MUL R0, 8
        MOV [R0 + WHIRLPOOL_K], [R0 + WHIRLPOOL_HASH]

        ; state[i] = block[i] ^ K[i]
        MOV R1, [R0 + WHIRLPOOL_BLOCK]
        XOR R1, [R0 + WHIRLPOOL_K]
        MOV [R0 + WHIRLPOOL_STATE], R1

        ; Repeat 8 times (once for each state)
        ADD C0, 1
        CMP C0, 8
        JMPC <LAB_WhirlPool_Hash_ApplyK0>, LT

    ; Iterate over all rounds (Probably pull this into a round function)
    MOV C0, 0
    <LAB_WhirlPool_Hash_RoundLoop>

        ; Compute K^r from K^{r-1}
        MOV C1, 0
        <LAB_WhirlPool_Hash_RoundLoop_Kr_1>
            MOV R0, C1
            MUL R0, 8
            ADD R0, WHIRLPOOL_L
            CALL <FUN_WhirlPool_LinearTransformation>, R0, WHIRLPOOL_C0, WHIRLPOOL_K, C1

            ADD C1, 1
            CMP C1, 8
            JMPC <LAB_WhirlPool_Hash_RoundLoop_Kr_1>, LT
        MOV C1, 0
        <LAB_WhirlPool_Hash_RoundLoop_Kr_2>
            MOV R0, C1
            MUL R0, 8
            MOV [R0 + WHIRLPOOL_K], [R0 + WHIRLPOOL_L]
            ADD C1, 1
            CMP C1, 8
            JMPC <LAB_WhirlPool_Hash_RoundLoop_Kr_2>, LT
        MOV R0, C0
        MUL R0, 8
        XOR [WHIRLPOOL_K], [R0 + WHIRLPOOL_RC]

        ; Apply the r-th round transformation
        MOV C1, 0
        <LAB_WhirlPool_Hash_RoundLoop_R_1>
            MOV R0, C1
            MUL R0, 8
            ADD R0, WHIRLPOOL_L
            CALL <FUN_WhirlPool_LinearTransformation>, R0, WHIRLPOOL_C0, WHIRLPOOL_STATE, C1
            MOV R1, C1
            MUL R1, 8
            ADD R1, WHIRLPOOL_K
            XOR [R0], [R1]
            ADD C1, 1
            CMP C1, 8
            JMPC <LAB_WhirlPool_Hash_RoundLoop_R_1>, LT
        MOV C1, 0
        <LAB_WhirlPool_Hash_RoundLoop_R_2>
            MOV R0, C1
            MUL R0, 8
            MOV [R0 + WHIRLPOOL_STATE], [R0 + WHIRLPOOL_L]
            ADD C1, 1
            CMP C1, 8
            JMPC <LAB_WhirlPool_Hash_RoundLoop_R_2>, LT

        ; Repeat for 10 rounds
        ADD C0, 1
        CMP C0, WHIRLPOOL_RNDS
        JMPC <LAB_WhirlPool_Hash_RoundLoop>, LT

    ; Apply the Miyaguchi-Preneel compression function
    MOV C0, 0
    <LAB_WhirlPool_Hash_Preneel>
        MOV R0, C0
        MUL R0, 8
        MOV R1, [R0 + WHIRLPOOL_STATE]
        XOR R1, [R0 + WHIRLPOOL_BLOCK]
        XOR [R0 + WHIRLPOOL_HASH], R1

        ADD C0, 1
        CMP C0, 8
        JMPC <LAB_WhirlPool_Hash_Preneel>, LT

    ; Return the virtual address of the hash
    RET WHIRLPOOL_HASH


;;;
; Perform a step in WHIRLPOOL where you do L[i] = (C0[a] ^ C1[b] ^ ... ^ C7[h])
; - param_1: Pointer in L to store the result
; - param_2: Pointer to the circulant tables, C0..C7
; - param_3: Pointer to deriver of a..h
; - param_4: Starting index for the deriver
;;;
<FUN_WhirlPool_LinearTransformation>
    ; Dereference the function parameters
    GET R0, 1
    GET C0, 2
    GET C1, 3
    GET C2, 4

    ; Intialize the value as 0
    MOV [R0], 0

    ; Perform THE LOOP
    MOV C3, 56
    <LAB_WhirlPool_LinearTransformation_Loop>
        MOV R1, C2
        MUL R1, 8
        MOV R1, [C1 + R1]
        SHR R1, C3
        AND R1, 0xFF
        MUL R1, 8
        MOV R1, [C0 + R1]
        XOR [R0], R1

        SUB C3, 8
        ADD C0, 0x800

        CMP C2, 0
        JMPC <LAB_WhirlPool_LinearTransformation_WrapAround>, EQ
            SUB C2, 1
            JMP <LAB_WhirlPool_LinearTransformation_WrapAroundFi>
        <LAB_WhirlPool_LinearTransformation_WrapAround>
            MOV C2, 7
        <LAB_WhirlPool_LinearTransformation_WrapAroundFi>

        CMP C0, WHIRLPOOL_C7
        JMPC <LAB_WhirlPool_LinearTransformation_Loop>, LTE

    ; Return a pointer to the data that was created
    RET R0


