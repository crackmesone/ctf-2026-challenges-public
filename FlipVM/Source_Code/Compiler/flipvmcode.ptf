    CALL <FUN_PrintBannerPiece>, 0x32231df7fcc893a39b797e4f30252cfbe2d69fa7967d7a53342930ffeed3b1ab88816a57462d1903f0d9e7af8f85725b4c313807f6cddab6b9896e5f6a35, 0x47ad4cd, 0x34
