{ ANSI_BACKGROUND   0x6d39353b31353b38333b323b38345b1b }
{ ANSI_ORANGE       0x6d31333b34373b3734313b323b38335b1b }
{ ANSI_YELLOW       0x6d37383b3933313b3239313b323b38335b1b }
{ ANSI_RED          0x6d38373b36343b3431323b323b38335b1b }
{ ANSI_BOLD         0x6d315b1b }
{ ANSI_NORMAL       0x6d305b1b }
{ ANSI_UP           0x465b1b }

{ WHIRLPOOL_RNDS    24} ; Number of WHIRLPOOL rounds (non-standard)

; WHIRLPOOL Memory Addresses
{ WHIRLPOOL_C0      0x000000 } ; 256 64-bit values  (0x800 bytes)
{ WHIRLPOOL_C1      0x000800 } ; 256 64-bit values  (0x800 bytes)
{ WHIRLPOOL_C2      0x001000 } ; 256 64-bit values  (0x800 bytes)
{ WHIRLPOOL_C3      0x001800 } ; 256 64-bit values  (0x800 bytes)
{ WHIRLPOOL_C4      0x002000 } ; 256 64-bit values  (0x800 bytes)
{ WHIRLPOOL_C5      0x002800 } ; 256 64-bit values  (0x800 bytes)
{ WHIRLPOOL_C6      0x003000 } ; 256 64-bit values  (0x800 bytes)
{ WHIRLPOOL_C7      0x003800 } ; 256 64-bit values  (0x800 bytes)
{ WHIRLPOOL_K       0x004000 } ; 8 64-bit values    (0x40 bytes)
{ WHIRLPOOL_BLOCK   0x004040 } ; 8 64-bit values    (0x40 bytes)
{ WHIRLPOOL_STATE   0x004080 } ; 8 64-bit values    (0x40 bytes)
{ WHIRLPOOL_L       0x0040C0 } ; 8 64-bit values    (0x40 bytes)
{ WHIRLPOOL_BUFFER  0x004100 } ; 64 1-byte values   (0x40 bytes)
{ WHIRLPOOL_HASH    0x004140 } ; 8 64-bit values    (0x40 bytes)
{ WHIRLPOOL_RC      0x004180 } ; 24 64-bit values   (0xC0 bytes)

; Kuznyechik Memory Addresses
{ KUZNYECHIK_K01    0x004240 } ; 2 64-bit values    (0x10 bytes)
{ KUZNYECHIK_K02    0x004250 } ; 2 64-bit values    (0x10 bytes)
{ KUZNYECHIK_K03    0x004260 } ; 2 64-bit values    (0x10 bytes)
{ KUZNYECHIK_K04    0x004270 } ; 2 64-bit values    (0x10 bytes)
{ KUZNYECHIK_K05    0x004280 } ; 2 64-bit values    (0x10 bytes)
{ KUZNYECHIK_K06    0x004290 } ; 2 64-bit values    (0x10 bytes)
{ KUZNYECHIK_K07    0x0042a0 } ; 2 64-bit values    (0x10 bytes)
{ KUZNYECHIK_K08    0x0042b0 } ; 2 64-bit values    (0x10 bytes)
{ KUZNYECHIK_K09    0x0042c0 } ; 2 64-bit values    (0x10 bytes)
{ KUZNYECHIK_K10    0x0042d0 } ; 2 64-bit values    (0x10 bytes)
{ KUZNYECHIK_PI     0x0042e0 } ; 256 8-bit values   (0x100 bytes)
{ KUZNYECHIK_INV    0x0043e0 } ; 256 8-bit values   (0x100 bytes)
{ KUZNYECHIK_V      0x0044e0 } ; 16 8-bit value     (0x10 bytes)
{ KUZNYECHIK_C      0x0044f0 } ; 32 128-bit value   (0x200 bytes)
{ KUZNYECHIK_TMP    0x0046f0 } ; 2 64-bit values    (0x10 bytes)
{ KUZNYECHIK_OUT    0x004700 } ; 2 64-bit values    (0x10 bytes)


;;;
; Print a piece of the banner that is encoded using Bytewise RLE of an XOR'd string
; - param_1: BigInt to decode
; - param_2: Time in nanoseconds to sleep between printing new lines
; - param_3: Initial XOR key
;;;
<FUN_PrintBannerPiece>
    GET P0, 1 ; Encoded, encrypted string
    GET P1, 2 ; Time to wait between new lines
    GET P2, 3 ; Starting XOR key

    ; Print Loop
    <Lab_PrintBannerPiece_NextWord>
        ; Switch to native mode since we only care about two bytes
        MODE 0

        ; Get the next word and decrypt it
        MOV R1, P0
        XOR R1, P2
        ADD P2, 0x15
        AND P2, 0xFF
        MOV R0, P2
        SHL R0, 8
        XOR R1, R0
        ADD P2, 0x15
        AND P2, 0xFF

        ; Split the word into key-cnt (R1-R2)
        MOV R2, R1
        AND R1, 0xFFFF
        SHR R1, 8
        AND R2, 0xFF
        CMP R2, 0
        JMPC <LAB_PrintBannerPiece_Done>, EQ

        ; Match the key to the character type in native mode
        MOV R4, <Lab_PrintBannerPiece_Ise>
        CMP R1, 0x00
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_Iscomma>
        CMP R1, 0x01
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_IsT>
        CMP R1, 0x02
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_Is2>
        CMP R1, 0x03
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_Isv>
        CMP R1, 0x04
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_Ism>
        CMP R1, 0x05
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_Isk>
        CMP R1, 0x06
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_Isspace>
        CMP R1, 0x07
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_IsC>
        CMP R1, 0x08
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_Isgrave>
        CMP R1, 0x09
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_IsF>
        CMP R1, 0x0a
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_Isb>
        CMP R1, 0x0b
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_Iss>
        CMP R1, 0x0c
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_Iso>
        CMP R1, 0x0d
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_Isapost>
        CMP R1, 0x0e
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_Isg>
        CMP R1, 0x0f
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_Isnewline>
        CMP R1, 0x10
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_IsP>
        CMP R1, 0x11
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_Isi>
        CMP R1, 0x12
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_Is6>
        CMP R1, 0x13
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_IsR>
        CMP R1, 0x14
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_Isa>
        CMP R1, 0x15
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_Isdot>
        CMP R1, 0x16
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_Isc>
        CMP R1, 0x17
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_Isn>
        CMP R1, 0x18
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_Isr>
        CMP R1, 0x19
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_IsE>
        CMP R1, 0x1a
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_Iscarrot>
        CMP R1, 0x1b
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_Is0>
        CMP R1, 0x1c
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_Is8>
        CMP R1, 0x1d
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_IsStar>
        CMP R1, 0x1e
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_IsBold>
        CMP R1, 0x20
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_IsNormal>
        CMP R1, 0x21
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_IsBackground>
        CMP R1, 0x22
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_IsOrange>
        CMP R1, 0x23
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_IsYellow>
        CMP R1, 0x24
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_IsRed>
        CMP R1, 0x25
        JMPC <Lab_PrintBannerPiece_CompDone>, EQ
        MOV R4, <Lab_PrintBannerPiece_IsUp>

        ; Jump to the dynamically computed jump destination in BigInt mode
        <Lab_PrintBannerPiece_CompDone>
        MODE 1
        JMP R4, 0

        <Lab_PrintBannerPiece_Ise>
            MOV R1, 0x65
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_Iscomma>
            MOV R1, 0x2C
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_IsT>
            MOV R1, 0x54
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_Is2>
            MOV R1, 0x32
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_Isv>
            MOV R1, 0x76
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_Ism>
            MOV R1, 0x6d
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_Isk>
            MOV R1, 0x6b
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_Isspace>
            MOV R1, 0x20
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_IsC>
            MOV R1, 0x43
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_Isgrave>
            MOV R1, 0x60
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_IsF>
            MOV R1, 0x46
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_Isb>
            MOV R1, 0x62
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_Iss>
            MOV R1, 0x73
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_Iso>
            MOV R1, 0x6f
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_Isapost>
            MOV R1, 0x27
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_Isg>
            MOV R1, 0x67
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_Isnewline>
            MOV R1, 0x0a
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_IsP>
            MOV R1, 0x50
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_Isi>
            MOV R1, 0x69
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_Is6>
            MOV R1, 0x36
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_IsR>
            MOV R1, 0x52
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_Isa>
            MOV R1, 0x61
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_Isdot>
            MOV R1, 0x2e
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_Isc>
            MOV R1, 0x63
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_Isn>
            MOV R1, 0x6e
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_Isr>
            MOV R1, 0x72
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_IsE>
            MOV R1, 0x45
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_Iscarrot>
            MOV R1, 0x5E
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_Is0>
            MOV R1, 0x30
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_Is8>
            MOV R1, 0x38
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_IsStar>
            MOV R1, 0x2A
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_IsBold>
            MOV R1, ANSI_BOLD
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_IsNormal>
            MOV R1, ANSI_NORMAL
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_IsBackground>
            MOV R1, ANSI_BACKGROUND
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_IsOrange>
            MOV R1, ANSI_ORANGE
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_IsYellow>
            MOV R1, ANSI_YELLOW
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_IsRed>
            MOV R1, ANSI_RED
            JMP <LAB_PrintBannerPiece_BuildString>
        <Lab_PrintBannerPiece_IsUp>
            MOV R1, ANSI_UP
            JMP <LAB_PrintBannerPiece_BuildString>

        ; Validate that there is a string
        <LAB_PrintBannerPiece_BuildString>
        MOV C0, 0

        ; Build the string in a register (XOR is forbidden due to small loop with many iterations)
        # tryXor = False
        MOV R3, R1
        <LAB_PrintBannerPiece_PrintLoop>
            PRINT R3
            ADD C0, 1
            CMP C0, R2
            JMPC <LAB_PrintBannerPiece_PrintLoop>, LT
        # tryXor = True

        ; If printing a new line, wait a bit
        CMP R1, 0x0a
        JMPC <LAB_PrintBannerPiece_SleepDone>, NEQ
            SLEEP 0, P1
        <LAB_PrintBannerPiece_SleepDone>

        ; Condtionally loop if the next byte is not zero
        SHR P0, 16
        CMP P0, 0
        JMPC <Lab_PrintBannerPiece_NextWord>, NEQ
    <LAB_PrintBannerPiece_Done>

    ; Return void
    MODE 1
    RET 0


;;;
; Print the welcome message
; - param_1: The encrypted message as a BigInt
; - param_2: Initial XOR key
; NOTE: The "customer ID" is P3, which is random in the release build
;;;
<FUN_PrintWelcomeMessage>
    ; Encrypted message and its seed
    GET P0, 1
    GET P1, 2
    MOV P2, 0

    ; Decrypt the start of the message
    MOV R0, P1
    <LAB_PrintWelcomeMessage_DecryptLoop>
        MOV R1, P0
        AND R1, 0xFF
        XOR R1, R0
        SHL P2, 8
        OR P2, R1

        MOV R0, R1
        SHR P0, 8
        CMP P0, 0
        JMPC <LAB_PrintWelcomeMessage_DecryptLoop>, NEQ

    ; Print the start of the message
    PRINT P2

    ; Begin bolding text and print #
    MOV P2, 0x23
    SHL P2, 32
    OR P2, ANSI_BOLD
    PRINT P2

    ; Print the random ID
    MODE 82
    MOV C0, 0x10
    <LAB_PrintWelcomeMessage_RandomLoop>
        MOV R0, P3
        AND R0, 0xFF
        MOD R0, 0x0A
        ADD R0, 0x30
        SHR P3, 4
        PRINT R0
        SUB C0, 1
        CMP C0, 0
        JMPC <LAB_PrintWelcomeMessage_RandomLoop>, GT

    ; Return text to normal
    PRINT ANSI_NORMAL
    PRINT 0x0a

    ; Return
    MODE 11
    RET 0


;;;
; Print the prompt for input (even though input is impossible)
; - param_1: String to decode as a BigInt
;;;
<FUN_PrintPrompt>
    GET R4, 1

    <LAB_PrintPrompt_Loop>
        MOV R0, R4
        AND R0, 0xFF
        MOV R1, R0
        AND R0, 0x0F
        AND R1, 0xF0
        SHL R0, 4
        SHR R1, 4
        OR R0, R1
        PRINT R0

        SHR R4, 8
        CMP R4, 0
        JMPC <LAB_PrintPrompt_Loop>, NEQ

    RET 0


;;;
; Print that there may be a skill issue
; - param_1: String to decode as a BigInt
;;;
<FUN_PrintSkillIssue>
    GET R0, 1
    MOV R2, 0
    MOV R3, 0

    <LAB_PrintSkillIssue_XorLoop>
        MOV R1, R0
        AND R1, 0xFF
        XOR R1, 0x38
        SHL R2, 8
        OR R2, R1
        SHR R0, 8
        CMP R0, 0
        JMPC <LAB_PrintSkillIssue_XorLoop>, NEQ
    PRINT R2
    RET 0


;;;
; Compiler-expected entry point
; Easiest solution:
;    1. Reverse the HashInput function
;    1. Solve for the input that resultes in a passing comparison
;    1. ADD a MOV instruction to fill R0 with the input
;    1. Adjust add bytes after the main function or remove bytes from before the main function to leave jump/call offsets in tact
;    1. Let the VM handle the rest
; VALID INPUT:  $?$__LeT_Th#_h@ck!ng_b3g1n__$?$ == 0x243f245f5f6e316733625f676e216b6340685f2368545f54654c5f5f243f24
; FLAG:         CMO{<-*~-~*~-.1'm++In.-~*~-~*->} == 7d3e2d2a7e2d7e2a 7e2d2e6e492b2b6d 27312e2d7e2a7e2d 7e2a2d3c7b4f4d43
;;;
<FUN_main>
    ; Print the banner
    # forceXor = True
    PRINT 0x00485b1b4a325b1b
    # forceXor = False
    MODE 1

    ; Print the overly complicated banner
    CALL <FUN_PrintBannerPiece>, 0xf6caaba08576414c3f2703f8f9c69ea48d7a45503b240ffeccd2a3a8b77e6d5f5d283200f1d6e1ac9f817352602e0704d3dac1b38c86750258323c08d4de, 0x457412e, 0xdf
    CALL <FUN_PrintBannerPiece>, 0xb77f74551c2b120af6d5e5ad8a834e5944240407cbdbd8b1b887765e57331a02e5dfd4b69e8b72655d373c0ef6e3cab9ad8f64654e3b2219f0e7ccbf8393, 0x684e5ae, 0x92
    CALL <FUN_PrintBannerPiece>, 0x92897d575c280103eadbd5af8480795b42311507ecddc6b39a8f785f54373b0be3e1d6b7a88d54634a3b350fe4e6c1bba2946662753d3a13dee9d4bdb497, 0x42c2644, 0x94
    CALL <FUN_PrintBannerPiece>, 0x16f5c5cda1a390796a4f1a2508fef8d2b5a796797a5619290effcad5b8a988834f575c2d3403ead2deadbd85725b66311c0cecdfe3b38089505f4e360f0b, 0x68bc6fb, 0x0a
    CALL <FUN_PrintBannerPiece>, 0x4f5645270500cad8d9aeb98477515b323806efdcebb2998b645e4d3d360aebe5dab6bf8c79624938320ee7e1c6babb907d66553c2612e3e8d5bead908b6a, 0x667a244, 0x6b
    CALL <FUN_PrintBannerPiece>, 0xc2af8480795b58311507ecddc6b39a897d5f54351e0bf2e3c0b7bc8f53635b393e0ff0e5ecbba2956664503d2017e0ecf7bfb4955c6b5243361525edcac3, 0x5145a74, 0xc2
    CALL <FUN_PrintBannerPiece>, 0xd2bfae97696b48440f171cedf4c3aa9b9e6d7d45321b26f1dcccac9fa3734049101f0ef7c2c091a19677424d30201df9e4c9afa5927e735126270afdfad3, 0x5d3e53f, 0xd2
    CALL <FUN_PrintBannerPiece>, 0xe6dadbb09586515c4f321008e9dbeeb4b68a6b604536010cffe2c0b8b98e7b64573a2810e1e6d3bcaf927568493c0e1416eacbc0a596a16c5f45201819ed, 0x4fadbf2, 0xef
    CALL <FUN_PrintBannerPiece>, 0xbd8a7f606f362505f6e2dfb8b9865e644d3a0510fbe4cfbe8c926368773e2d1f1de8f2c0b196a16c5f49331a20eec7c4939a81734c46351b1ef2c3cd909e, 0x461ca4c, 0x9f
    CALL <FUN_PrintBannerPiece>, 0x1fecfbc2a99b946e5d40261a1bf5f8c6a49c95725748171e0df6eecaaba3a876744c252207f8c7cebda69e7a7b503d2615fce6d2a3a89f7e7756642a0000, 0x5e47d8a, 0x01
    CALL <FUN_PrintBannerPiece>, 0x5e69543b2715e2ebd4c1ac978f6d4a41091915efc4c5a69ba6715c562c1823f3c0c9909f8e774249112116f7c2cdb0a8907b474f24252cfbe2daa6a5b57d, 0x5d2ae1c, 0x7c
