    CALL <FUN_PrintBannerPiece>, 0xa56f4945280e1bc7dcd2979d97735a5b2d270ee7f9cba5a18c647f7730302bf9f3cfbeb5914762411d2701fde0c2a397946e4f552f2b120ff597c6a3b183, 0xa81865, 0x82
    CALL <FUN_PrintBannerPiece>, 0xfeffe9bbb5917c7c4f172008dbe9c3bfae8d614752590d1711edd0dab3b784767f453f1b02e7c5f7b68ba1734d49340817c7d8dc93a19b77665929170aed, 0x86ed7b, 0xf8
    CALL <FUN_PrintBannerPiece>, 0xc4d8b7baa0704c46353d16ecd9e9929e9a74675428000be8c4cca8a289677a6c3d3b36faf6d0bbba8c586f4e182804feedc9de8c919d4a56522c1f18f0f0, 0xffa28c, 0xd9
    CALL <FUN_PrintBannerPiece>, 0x8e53415b32072df7f1cdb084936b64681f251ffbe2f5a5b3965941532d2914daf7c3b88eb3817b57460f091beafbe5af898568785b2b1c24d7ddd7b39aa9, 0xfedbc7, 0x88
    CALL <FUN_PrintBannerPiece>, 0xdcb6a5a066664914020eeae4d797b8967b4b743c3812f9c2cab6adbea66a46402b3d1ce6dfe98898946e5d6c2e1601d8fac6a29c8f5b404633372cf4f0ca, 0xe9c0c8, 0xcb
    CALL <FUN_PrintBannerPiece>, 0x301b06f1dcc7b29d88735e49341f0af5e0cbb6a18c77624d38230ef9e4cfbaa5907b76531d2615a2ced2aea89350745447043000fcd6c58386806977622e, 0xd58de6, 0x2f

    ; Print the welcome message and useless customer ID
    CALL <FUN_PrintWelcomeMessage>, 0x3c090f054b59161a5546091d5242070c07094741414c0316180d4c431606071b0208175c0e79361a0752431606071b02081752690d64491a53b9, 0x99

